# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Each var: what it is + where to get it.

# App
PORT=3000
NODE_ENV=development

# Redis (local dev: docker run -d -p 6379:6379 redis:latest)
REDIS_URL=redis://127.0.0.1:6379/0

# Example third-party key (get from the provider dashboard)
# SOME_API_KEY=
